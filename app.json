{
  "expo": {
    "name": "Tune",
    "slug": "tune",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tune",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.renatovanerven.tune"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F3ED",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.renatovanerven.tune",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      "expo-sqlite",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4A3048"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Tune uses your photo library to estimate meal nutrition from pictures.",
          "cameraPermission": "Tune uses your camera to photograph meals for nutrition estimates."
        }
      ]
    ]
  }
}
