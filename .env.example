# Mobile app AI proxy URL. Use a deployed HTTPS URL for TestFlight builds.
EXPO_PUBLIC_AI_PROXY_URL=
EXPO_PUBLIC_AI_MOCK=false

# Server-side Gemini settings for `npm run ai-proxy` or the deployed proxy.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_PROXY_PORT=8787

# Local development only. Do not enable this for TestFlight/App Store builds.
EXPO_PUBLIC_ENABLE_DIRECT_GEMINI=false

# Public RevenueCat SDK config
REVENUECAT_APPLE_API_KEY=appl_KROjCpNxXXTwqfAyQhfebGiVhUy
REVENUECAT_ENTITLEMENT_ID=BetterMe Premium
