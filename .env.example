# Direct Gemini from the mobile app (no backend)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: local proxy server (only if GEMINI_API_KEY is unset)
# GEMINI_API_KEY and GEMINI_MODEL are still used by `npm run ai-proxy`
AI_PROXY_PORT=8787
EXPO_PUBLIC_AI_PROXY_URL=

# Optional: canned AI responses for development
EXPO_PUBLIC_AI_MOCK=false
